<idea-plugin>
    <id>io.dyuti.osvplugin</id>
    <name>OSV Vulnerability Scanner</name>
    <vendor email="support@dyuti.io" url="https://github.com/dyuti/jetbrains-osv-plugin">Dyuti</vendor>
    
    <description><![CDATA[
    A free, open-source IntelliJ IDEA plugin that provides security vulnerability scanning for open-source dependencies using the OSV (Open Source Vulnerabilities) database.
    ]]></description>
    
    <version>1.1.0</version>
    
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    
    <actions>
        <!-- Add actions here if needed -->
    </actions>
    
    <application-components>
        <!-- Application-level components -->
    </application-components>
    
    <project-components>
        <!-- Project-level components -->
    </project-components>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- OSV Inspection for manifest files (XML = pom.xml, Groovy = build.gradle, kotlin = build.gradle.kts, JSON = package.json) -->
        <localInspection
            language="JAVA"
            shortName="OsVInspection"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language="XML"
            shortName="OsVInspectionXml"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language="Groovy"
            shortName="OsVInspectionGroovy"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language="kotlin"
            shortName="OsVInspectionKotlin"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language="JSON"
            shortName="OsVInspectionJson"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language=""
            shortName="OsVInspectionPlainText"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <!-- License Inspection -->
        <localInspection
            language="JAVA"
            shortName="LicenseInspection"
            displayName="License Compliance Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.license.LicenseInspection"/>
        
        <!-- Settings Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.settings.OsVConfigurable"
            parentId="tools"
            displayName="OSV Scanner"
            id="osv.scanner.settings"/>
        
        <!-- License Policy Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.license.LicensePolicyConfigurable"
            parentId="osv.scanner.settings"
            displayName="License Policy"
            id="osv.scanner.license"/>
        
        <!-- Privacy Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.privacy.PrivacyConfigurable"
            parentId="osv.scanner.settings"
            displayName="Privacy"
            id="osv.scanner.privacy"/>
        
        <!-- Tool Window Factory -->
        <toolWindow
            id="OSV Vulnerability Scanner"
            factoryClass="io.dyuti.osvplugin.toolwindow.OsVToolWindowFactory"
            anchor="bottom"
            icon="/icons/osv-icon-48.png"/>
        
        <!-- Configuration -->
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.config.OsVConfig"/>
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.license.LicensePolicyConfig"/>
        
        <!-- Organization Service -->
        <projectService
            serviceImplementation="io.dyuti.osvplugin.organization.OrganizationManager"/>
        <projectService
            serviceImplementation="io.dyuti.osvplugin.organization.TeamPermissionService"/>
        
        <!-- Jira Integration -->
        <projectService
            serviceImplementation="io.dyuti.osvplugin.integration.JiraConnector"/>
        <projectService
            serviceImplementation="io.dyuti.osvplugin.integration.JiraIssueCreator"/>
    </extensions>
    
    <resource-bundle>OsVBundle</resource-bundle>
</idea-plugin>
