<idea-plugin>
    <id>io.dyuti.osvplugin</id>
    <name>OSV Vulnerability Scanner</name>
    <vendor email="support@dyuti.io" url="https://github.com/dyuti/jetbrains-osv-plugin">Dyuti Open Source</vendor>
    
    <description><![CDATA[
<p>A free, open-source security vulnerability scanner for open-source dependencies, powered by the OSV (Open Source Vulnerabilities) database.</p>
<p><b>Features:</b></p>
<ul>
  <li>Real-time vulnerability scanning for Maven, Gradle, npm, and pip dependencies</li>
  <li>Inline inspection highlights with Alt+Enter quick fixes</li>
  <li>Risk scoring with EPSS + CISA KEV for exploitability-based prioritization</li>
  <li>Malicious package detection (typosquatting, homoglyph, known malware)</li>
  <li>Basic SAST for SQL injection, XSS, and path traversal</li>
  <li>Privacy-preserving mode — hash package names in UI, logs, and exports</li>
  <li>Policy enforcement with severity, CVSS, and license compliance rules</li>
  <li>Team configuration sharing via version-controllable JSON</li>
  <li>Differential analysis to compare scans between branches or snapshots</li>
  <li>Historical trending with ASCII sparklines</li>
  <li>SBOM generation in CycloneDX 1.5 and SPDX 2.3 formats</li>
  <li>Configuration audit for Spring / Hibernate insecure settings</li>
  <li>IDE balloon notifications for discovered vulnerabilities</li>
  <li>SARIF export for CI/CD integration</li>
</ul>
<p><b>Why OSV Plugin?</b></p>
<ul>
  <li>100% free — no API key or subscription required</li>
  <li>Uses the open OSV database instead of commercial APIs</li>
  <li>Enterprise-grade features (risk scoring, policy enforcement, team config) at zero cost</li>
</ul>
    ]]></description>
    
    <category>Security</category>
    
    <version>1.1.1</version>
    
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    
    <actions>
        <!-- Add actions here if needed -->
    </actions>
    
    <application-components>
        <!-- Application-level components -->
    </application-components>
    
    <project-components>
        <!-- Project-level components -->
    </project-components>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- OSV Inspection for manifest files (XML = pom.xml, Groovy = build.gradle, kotlin = build.gradle.kts, JSON = package.json) -->
        <localInspection
            language="JAVA"
            shortName="OsVInspection"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspection"/>
        
        <localInspection
            language="XML"
            shortName="OsVInspectionXml"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspectionXml"/>
        
        <localInspection
            language="Groovy"
            shortName="OsVInspectionGroovy"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspectionGroovy"/>
        
        <localInspection
            language="kotlin"
            shortName="OsVInspectionKotlin"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspectionKotlin"/>
        
        <localInspection
            language="JSON"
            shortName="OsVInspectionJson"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspectionJson"/>
        
        <localInspection
            language=""
            shortName="OsVInspectionPlainText"
            displayName="OSV Vulnerability Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.inspection.OsVInspectionPlainText"/>
        
        <!-- License Inspection -->
        <localInspection
            language="JAVA"
            shortName="LicenseInspection"
            displayName="License Compliance Check"
            groupName="Security"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.dyuti.osvplugin.license.LicenseInspection"/>
        
        <!-- Settings Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.settings.OsVConfigurable"
            parentId="tools"
            displayName="OSV Scanner"
            id="osv.scanner.settings"/>
        
        <!-- License Policy Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.license.LicensePolicyConfigurable"
            parentId="osv.scanner.settings"
            displayName="License Policy"
            id="osv.scanner.license"/>
        
        <!-- Privacy Configurable -->
        <applicationConfigurable
            instance="io.dyuti.osvplugin.privacy.PrivacyConfigurable"
            parentId="osv.scanner.settings"
            displayName="Privacy"
            id="osv.scanner.privacy"/>
        
        <!-- Tool Window Factory -->
        <toolWindow
            id="OSV Vulnerability Scanner"
            factoryClass="io.dyuti.osvplugin.toolwindow.OsVToolWindowFactory"
            anchor="bottom"
            icon="/icons/osv-icon-48.png"/>
        
        <!-- Notification Group -->
        <notificationGroup id="OSV Vulnerability Alerts" displayType="BALLOON" toolWindowId="OSV Vulnerability Scanner"/>
        
        <!-- Configuration -->
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.utils.CacheManager"/>
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.api.OsVApiService"/>
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.config.OsVConfig"/>
        <applicationService
            serviceImplementation="io.dyuti.osvplugin.license.LicensePolicyConfig"/>
        
        <!-- Organization Service -->
        <projectService
            serviceImplementation="io.dyuti.osvplugin.organization.OrganizationManager"/>
        <projectService
            serviceImplementation="io.dyuti.osvplugin.organization.TeamPermissionService"/>
        
        <!-- Status Bar Widget -->
        <statusBarWidgetFactory
            implementation="io.dyuti.osvplugin.statusbar.OsvStatusBarWidgetFactory"
            id="osv.statusBar"/>
        
        <!-- Jira Integration -->
        <projectService
            serviceImplementation="io.dyuti.osvplugin.integration.JiraConnector"/>
        <projectService
            serviceImplementation="io.dyuti.osvplugin.integration.JiraIssueCreator"/>
    </extensions>
    
    <resource-bundle>OsVBundle</resource-bundle>
</idea-plugin>
